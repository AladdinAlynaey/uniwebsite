# ============================================
# AI PROVIDER CONFIGURATION
# ============================================

# Active AI Provider (gemini, openrouter, or groq)
# Can also be changed from Admin Settings
AI_PROVIDER=gemini

# ============================================
# GOOGLE GEMINI CONFIGURATION
# Get your API keys from: https://aistudio.google.com/apikey
# ============================================

# Gemini Model Name
GEMINI_MODEL_NAME=gemini-2.0-flash

# Multiple API Keys for automatic rotation (the system rotates when one hits quota)
GEMINI_API_KEY_1=your_first_api_key_here
GEMINI_API_KEY_2=your_second_api_key_here
GEMINI_API_KEY_3=your_third_api_key_here
GEMINI_API_KEY_4=your_fourth_api_key_here
GEMINI_API_KEY_5=your_fifth_api_key_here

# ============================================
# OPENROUTER CONFIGURATION
# Get your API key from: https://openrouter.ai/keys
# Free models available!
# ============================================

OPENROUTER_API_KEY=your_openrouter_key_here

# OpenRouter Model (free models end with :free)
# Available free models:
# - google/gemini-2.0-flash-exp:free
# - meta-llama/llama-3.2-3b-instruct:free
# - qwen/qwen-2-7b-instruct:free
# - mistralai/mistral-7b-instruct:free
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ============================================
# GROQ CONFIGURATION
# Get your API key from: https://console.groq.com/keys
# Fast inference with generous free tier!
# ============================================

GROQ_API_KEY=your_groq_key_here

# Groq Model
# Available models:
# - llama-3.3-70b-versatile (recommended)
# - llama-3.1-70b-versatile
# - llama-3.1-8b-instant (fastest)
# - mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================
# FLASK CONFIGURATION
# ============================================

FLASK_ENV=development
SECRET_KEY=your-secret-key-here
DEBUG=True

# ============================================
# TELEGRAM BOT (Optional)
# Create a bot with @BotFather on Telegram
# ============================================

# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_BOT_USERNAME=your_bot_username
